# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and stays on your machine / in Vercel only.

# --- Supabase (server-side only) ---
# Project Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Dodo Payments (server-side only) ---
# Dashboard -> Developer -> API Keys (use the test key first, then live)
DODO_PAYMENTS_API_KEY=
DODO_ENVIRONMENT=test_mode           # test_mode | live_mode
# Dashboard -> Developer -> Webhooks -> your endpoint signing secret
DODO_WEBHOOK_KEY=
# Product IDs from Dodo (one per plan)
DODO_PRODUCT_MONTHLY=
DODO_PRODUCT_ANNUAL=
DODO_PRODUCT_LIFETIME=

# --- Site ---
# Optional: canonical URL used for checkout return_url (defaults to request origin)
NEXT_PUBLIC_SITE_URL=
