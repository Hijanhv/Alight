# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and stays on your machine / in Vercel only.

# --- Supabase (server-side only) ---
# Project Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email, server-side only) ---
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=
# From address. For testing you can use: Alight <onboarding@resend.dev>
# For production, verify your domain in Resend, e.g. Alight <hello@yourdomain>
RESEND_FROM=Alight <onboarding@resend.dev>

# --- Site ---
# Used for links inside emails (defaults to the live URL if unset).
NEXT_PUBLIC_SITE_URL=https://alight-seven.vercel.app
