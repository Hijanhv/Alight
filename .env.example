# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and stays on your machine / in Vercel only.

# --- Supabase (server-side only) ---
# Create a free project at https://supabase.com
# Then: Project Settings -> API
#   SUPABASE_URL              = "Project URL"
#   SUPABASE_SERVICE_ROLE_KEY = "service_role" secret key  (NEVER expose to the browser,
#                               never prefix with NEXT_PUBLIC, never commit it)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
