# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and stays on your machine / in Vercel only.

# --- Supabase (server-side only) ---
# Project Settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email, server-side only) ---
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=
RESEND_FROM=Alight <onboarding@resend.dev>

# --- Free AI for the Lily & John friends (server-side only) ---
# Add EITHER one (Groq recommended — fast + free). If neither is set, the
# friends still work using on-brand template replies.
# Groq keys: https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# Google Gemini (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash

# --- Memory for Lily & John (server-side) ---
# How the friends remember people across chats. "supabase" (default) keeps a
# small private memory profile in your Supabase — $0, no extra service.
# Switch to "cognee" once a Cognee memory host is set up.
MEMORY_PROVIDER=supabase

# --- Site ---
# Used for links inside emails (defaults to the live URL if unset).
NEXT_PUBLIC_SITE_URL=https://alight-seven.vercel.app
